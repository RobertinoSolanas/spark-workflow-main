# =============================================================================
# modul-inhaltsextraktion — shared development config (tracked in git)
# Secrets and per-developer overrides go in .env (gitignored)
# =============================================================================

ENV=development

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# -----------------------------------------------------------------------------
LITELLM_BASE_URL=https://your-litellm-proxy.example.com/v1

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
DMS_BASE_URL="http://localhost:8888"

# LibreOffice UNO
UNO_HOST="localhost"
UNO_PORT="2003"
UNO_PROTOCOL="http"

# -----------------------------------------------------------------------------
# Extraction Provider
# -----------------------------------------------------------------------------
EXTRACTION_PROVIDER=docling

# Docling — local
DOCLING_PROTOCOL=http
DOCLING_HOST=localhost
DOCLING_PORT=5001
DOCLING_OCR_ENGINE=easyocr  # "rapidocr" for CPU, "easyocr" for GPU

# -----------------------------------------------------------------------------
# LLM Models (routed via LiteLLM — only model names needed)
# -----------------------------------------------------------------------------
VLLM_MODEL="mistral-small-24b-instruct"
METADATA_MODEL_NAME="gpt-oss-120b"
SCHWERPUNKTTHEMA_MODEL_NAME="gpt-oss-120b"
SUMMARIZATION_MODEL_NAME="gpt-oss-120b"
VLM_SUMMARY_MODEL_NAME="gpt-oss-120b"
STRUCTURE_MODEL_NAME="gpt-oss-120b"

# -----------------------------------------------------------------------------
# Throttle Settings — Mistral API (6 req/s = 360 req/min limit)
# -----------------------------------------------------------------------------
# THROTTLE_GLOBAL: hard ceiling across all models sharing the API
# VLM Phase 1+2 run sequentially before enrichment → get full budget.
# Enrichment runs 5 throttles concurrently → 70/min each (≤350/min combined).
THROTTLE_GLOBAL='{"MAX_CONCURRENT": 40, "RATE_PER_MINUTE": 340}'
THROTTLE_VLM='{"MAX_CONCURRENT": 20, "RATE_PER_MINUTE": 300}'
THROTTLE_VLM_SUMMARY='{"MAX_CONCURRENT": 20, "RATE_PER_MINUTE": 300}'
THROTTLE_SUMMARIZATION='{"MAX_CONCURRENT": 10, "RATE_PER_MINUTE": 70}'
THROTTLE_SCHWERPUNKTTHEMA='{"MAX_CONCURRENT": 10, "RATE_PER_MINUTE": 70}'
THROTTLE_METADATA='{"MAX_CONCURRENT": 10, "RATE_PER_MINUTE": 70}'
THROTTLE_HYPOTHETICAL_QUESTIONS='{"MAX_CONCURRENT": 10, "RATE_PER_MINUTE": 70}'
THROTTLE_SPECIES_SCALE='{"MAX_CONCURRENT": 10, "RATE_PER_MINUTE": 70}'

# -----------------------------------------------------------------------------
# Qdrant / Embedding
# -----------------------------------------------------------------------------
QDRANT_BASE_URL="http://localhost:6333"
QDRANT_DENSE_VECTOR_SIZE=1024
EMBEDDING_MODEL="BAAI/bge-m3"


# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------
TEMPORAL_SERVER_URL="localhost:7233"
TEMPORAL_TASK_QUEUE="extraction"
TEMPORAL_S3_BUCKET_NAME=temporal-payloads
TEMPORAL_S3_ENDPOINT_URL=http://localhost:9000
# TEMPORAL_S3_ACCESS_KEY_ID=<set me in .env>
# TEMPORAL_S3_SECRET_ACCESS_KEY=<set me in .env>
TEMPORAL_S3_REGION=eu-west-1

# -----------------------------------------------------------------------------
# Workflow Settings
# -----------------------------------------------------------------------------
SINGLE_DOCUMENT_WORKFLOW_CONCURRENCY=6 # how many documents get processed in parallel in the single-document workflow 
EXTRACTION_CHUNK_CONCURRENCY=2 # how many document chunks docling processes in parallel for big documents > 40 MB. Smaller documents do not get chunked

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME="inhaltsextraktion"
OTEL_ENDPOINT="http://localhost:4317"
