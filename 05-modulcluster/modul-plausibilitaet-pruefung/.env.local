# LiteLLM Proxy
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MODEL=gpt-oss-120b
LITELLM_EMBEDDING_MODEL=BAAI/bge-m3

# Qdrant
QDRANT_CLUSTER_ENDPOINT=http://localhost:6333
QDRANT_VECTOR_SIZE=1024  # Must match the output dimensions of the embedding model (e.g. BAAI/bge-m3 = 1024)

# DMS
DMS_BASE_URL=http://localhost:8000

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=plausibilitaet-pruefung
TEMPORAL_LLM_MAX_PER_SECOND=3
TEMPORAL_S3_BUCKET_NAME=temporal-payloads
TEMPORAL_S3_ENDPOINT_URL=http://localhost:9000
# TEMPORAL_S3_ACCESS_KEY_ID=<set me in .env>
# TEMPORAL_S3_SECRET_ACCESS_KEY=<set me in .env>
TEMPORAL_S3_REGION=eu-west-1

# OpenTelemetry
OTEL_SERVICE_NAME=plausibilitaet_pruefung
OTEL_ENDPOINT=http://localhost:4317
